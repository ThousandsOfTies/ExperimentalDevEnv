{
  "name": "AArch64-Simulation-Env",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu@sha256:8899808381cc714d56d7733a1e944b08709087d004655497241280629ec2d97f", // ARM64版を直接指名
  "runArgs": [
    "--platform", "linux/arm64",
    "--device", "/dev/fuse"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "akiyosi.emacs-keybindings"
      ]
    }
  },
  "postCreateCommand": "apt-get update && apt-get install -y build-essential python3 python3-pip file kmod"
}
